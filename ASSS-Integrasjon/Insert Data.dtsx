                    <arrayElement
                      dataType="System.String"><![CDATA[#region Help:  Introduction to the Script Component
/* The Script Component allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services data flow.
 *
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script component. */
#endregion

#region Namespaces
using System;
using System.Collections.Generic;
using System.Data;
using System.Data.SqlClient;
using System.Linq;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
#endregion

/// <summary>
/// This is the class to which to add your code.  Do not change the name, attributes, or parent
/// of this class.
/// </summary>
[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    #region Help:  Using Integration Services variables and parameters
    /* To use a variable in this script, first ensure that the variable has been added to
     * either the list contained in the ReadOnlyVariables property or the list contained in
     * the ReadWriteVariables property of this script component, according to whether or not your
     * code needs to write into the variable.  To do so, save this script, close this instance of
     * Visual Studio, and update the ReadOnlyVariables and ReadWriteVariables properties in the
     * Script Transformation Editor window.
     * To use a parameter in this script, follow the same steps. Parameters are always read-only.
     *
     * Example of reading from a variable or parameter:
     *  DateTime startTime = Variables.MyStartTime;
     *
     * Example of writing to a variable:
     *  Variables.myStringVariable = "new value";
     */
    #endregion

    #region Help:  Using Integration Services Connnection Managers
    /* Some types of connection managers can be used in this script component.  See the help topic
     * "Working with Connection Managers Programatically" for details.
     *
     * To use a connection manager in this script, first ensure that the connection manager has
     * been added to either the list of connection managers on the Connection Managers page of the
     * script component editor.  To add the connection manager, save this script, close this instance of
     * Visual Studio, and add the Connection Manager to the list.
     *
     * If the component needs to hold a connection open while processing rows, override the
     * AcquireConnections and ReleaseConnections methods.
     * 
     * Example of using an ADO.Net connection manager to acquire a SqlConnection:
     *  object rawConnection = Connections.SalesDB.AcquireConnection(transaction);
     *  SqlConnection salesDBConn = (SqlConnection)rawConnection;
     *
     * Example of using a File connection manager to acquire a file path:
     *  object rawConnection = Connections.Prices_zip.AcquireConnection(transaction);
     *  string filePath = (string)rawConnection;
     *
     * Example of releasing a connection manager:
     *  Connections.SalesDB.ReleaseConnection(rawConnection);
     */
    #endregion

    #region Help:  Firing Integration Services Events
    /* This script component can fire events.
     *
     * Example of firing an error event:
     *  ComponentMetaData.FireError(10, "Process Values", "Bad value", "", 0, out cancel);
     *
     * Example of firing an information event:
     *  ComponentMetaData.FireInformation(10, "Process Values", "Processing has started", "", 0, fireAgain);
     *
     * Example of firing a warning event:
     *  ComponentMetaData.FireWarning(10, "Process Values", "No rows were received", "", 0);
     */
    #endregion
    private SqlConnection scn;
    private SqlCommand command;
    private SqlDataReader dataReader;
    private string connectionString, sqlString;
    private string tableName;
    private bool debug;

    /// <summary>
    /// This method is called once, before rows begin to be processed in the data flow.
    ///
    /// You can remove this method if you don't need to do anything here.
    /// </summary>
    public override void PreExecute()
    {
        base.PreExecute();
        tableName = "SSB_" + Variables.Tablenumber;
        // Set the connectionString and the SqlConnection
        connectionString = @"Data Source=vk-sxd0e-003;Initial Catalog=TEST_Staging_ASSS;Integrated Security=true";
        scn = new SqlConnection(connectionString);

        // Set the sqlString and the Sql command
        sqlString = $"select COLUMN_NAME, DATA_TYPE, CHARACTER_MAXIMUM_LENGTH, NUMERIC_PRECISION, NUMERIC_SCALE from INFORMATION_SCHEMA.columns where TABLE_NAME = '{tableName}'";
        command = new SqlCommand(sqlString, scn);
        debug = true;
    }

    public Dictionary<string, string> ReadFromSQL2(bool debug)
    {
        // A dictionary of dictionaries that contain information about the columns
        Dictionary<string, string> columnDeclarations = new Dictionary<string, string>();

        ComponentMetaData.FireInformation(1, "ReadFromSQL2", "starting", "", 0, ref debug);

        // Open the SQL connection
        ComponentMetaData.FireInformation(1, "SQL Connection", "opening", "", 0, ref debug);
        scn.Open();
        ComponentMetaData.FireInformation(1, "SQL Connection", "open", "", 0, ref debug);

        // Execute the SQL command
        ComponentMetaData.FireInformation(1, "Data reader", "executing", "", 0, ref debug);
        dataReader = command.ExecuteReader();

        // Read the result of the command into the dictionary
        ComponentMetaData.FireInformation(1, "Data reader", "starting to read data from table " + Variables.Tablenumber, "", 0, ref debug);
        while (dataReader.Read())
        {
            string columnName = (string)dataReader.GetValue(0);
            string dataType = (string) dataReader.GetValue(1);

            ComponentMetaData.FireInformation(1, "Data reader", "reading column " + dataReader.GetValue(0), "", 0, ref debug);

            switch (dataType)
            {
                case "varchar":
                    columnDeclarations.Add(columnName, $"varchar ({dataReader.GetValue(2)})");
                    break;
                case "numeric":
                    columnDeclarations.Add(columnName, $"numeric ({dataReader.GetValue(3)}, {dataReader.GetValue(4)})");
                    break;
                case "int":
                    columnDeclarations.Add(columnName, $"int");
                    break;
            }
        }
        ComponentMetaData.FireInformation(1, "Data reader", "finished", "", 0, ref debug);

        // Close the datareader
        ComponentMetaData.FireInformation(1, "Data reader", "closing", "", 0, ref debug);
        dataReader.Close();
        ComponentMetaData.FireInformation(1, "Data reader", "closed", "", 0, ref debug);

        // Clear the command
        command.Dispose();

        // Close the server connection
        ComponentMetaData.FireInformation(1, "SQL Connection", "closing", "", 0, ref debug);
        scn.Close();
        ComponentMetaData.FireInformation(1, "SQL Connection", "closed", "", 0, ref debug);

        ComponentMetaData.FireInformation(1, "ReadFromSQL2", "ending", "", 0, ref debug);

        return columnDeclarations;
    }

    public string buildDeclareString(Dictionary<string, string> columnDeclarations)
    {
        ComponentMetaData.FireInformation(1, "buildDeclareString", "starting", "", 0, true);
        string tDeclares = "", 
            mDeclares = "";

        foreach(KeyValuePair<string, string> kvp in columnDeclarations)
        {
            ComponentMetaData.FireInformation(1, "key", kvp.Key, "", 0, true);
            ComponentMetaData.FireInformation(1, "value", kvp.Value, "", 0, true);
            // t has only the columns with kode in its name
            if (!kvp.Key.Contains("navn"))
            {
                tDeclares = string.Concat(tDeclares, $"[{kvp.Key}] {kvp.Value}");

                // Need to add a comma if its not the last one
                if (columnDeclarations.Keys.Last() != kvp.Key)
                    tDeclares = string.Concat(tDeclares, ", ");
            }
            
            // m has all the columns available
            mDeclares = string.Concat(mDeclares, $"[{kvp.Key}] {kvp.Value}");

            // Since Tid is defined twice we need to handle this
            if (kvp.Key.Equals("Tid"))
                mDeclares = string.Concat(mDeclares, $", [{kvp.Key}2] {kvp.Value}");

            // Since t gets it comma in the first if then we only need to add it on m
            if (columnDeclarations.Keys.Last() != kvp.Key)
                mDeclares = string.Concat(mDeclares, ", ");
        }

        ComponentMetaData.FireInformation(1, "buildDeclareString", "ending", "", 0, true);
        return $"declare @t table ({tDeclares})\ndeclare @m table ({mDeclares})\n";
    }

    public string buildSelectString(Dictionary<string, string> columnDeclarations)
    {
        string selectString = "";
        int count = 0;

        foreach (KeyValuePair<string, string> kvp in columnDeclarations)
        {
           if (!kvp.Key.Contains("navn"))
            {
                selectString = string.Concat(selectString, $"dat.[{kvp.Key}]");
            } else
            {
                selectString = string.Concat(selectString, $"met{count}.[{kvp.Key}]");
                count++;
            }

           if (kvp.Key != columnDeclarations.Keys.Last())
            {
                selectString = string.Concat(selectString, ",\n\t");
            } else
            {
                selectString = string.Concat(selectString, "\n\t");
            }
        }

        return selectString;
    }

    public string buildJoinString(Dictionary<string, string> columnDeclarations)
    {
        string joinString = "";
        int count = 0;

        foreach (KeyValuePair<string, string> kvp in columnDeclarations)
        {
            string replacedColumnName = kvp.Key.Replace("navn", "kode");

            if (kvp.Key.Contains("navn"))
            {
                joinString = string.Concat(joinString, $"join @m met{count} ON met{count}.[{replacedColumnName}] = dat.[{replacedColumnName}]\n");
                count++;
            }
        }

        return joinString;
    }

    public string buildInsertIntoTablesString(Dictionary<string, string> columnDeclarations)
    {
        string insertString = "";
        if (Variables.Filters.Equals(""))
        {
            insertString = $"insert @t Exec SSB_Values_AlleAar2 @TabellNummer='{Variables.Tablenumber}'\n";
            insertString = string.Concat(insertString, $"insert @m Exec SSB_Metadata @TabellNummer='{Variables.Tablenumber}'\n");
        } else
        {
            insertString = $"insert @t Exec SSB_Values_AlleAar2 @TabellNummer='{Variables.Tablenumber}' @Filter={Variables.Filters}\n";
            insertString = string.Concat(insertString, $"insert @m Exec SSB_Metadata @TabellNummer='{Variables.Tablenumber}' @Filter={Variables.Filters}\n");
        }

        return insertString;
    }

    public string buildInsertQueryString(string declares, string inserts, string select, string joins)
    {
        string insertString = $"{declares}\n{inserts}\nTruncate Table [{tableName}]\nInsert Into [{tableName}]\nselect {select}\nfrom @t dat\n{joins}";

        return insertString;
    }

    public void executeSqlCommand(string sqlCommand, bool debug)
    {
        // Open the SQL connection
        ComponentMetaData.FireInformation(1, "SQL Connection", "opening", "", 0, ref debug);
        scn.Open();
        ComponentMetaData.FireInformation(1, "SQL Connection", "open", "", 0, ref debug);


        command = new SqlCommand(sqlCommand, scn);

        if (Variables.Tablenumber.Equals("12367"))
        {
            
        } else
        {
            command.CommandTimeout = 500;
        }

        // Execute the SQL command
        ComponentMetaData.FireInformation(1, "SqlCommand", "executing", "", 0, ref debug);
        command.ExecuteNonQuery();
        ComponentMetaData.FireInformation(1, "SqlCommand", "done", "", 0, ref debug);

        // Execute the SQL command
        ComponentMetaData.FireInformation(1, "SqlCommand", "disposing", "", 0, ref debug);
        command.Dispose();
        ComponentMetaData.FireInformation(1, "SqlCommand", "disposed", "", 0, ref debug);

        // Close the server connection
        ComponentMetaData.FireInformation(1, "SQL Connection", "closing", "", 0, ref debug);
        scn.Close();
        ComponentMetaData.FireInformation(1, "SQL Connection", "closed", "", 0, ref debug);
    }

    public override void CreateNewOutputRows()
    {
        string declareString, insertString, selectString, joinString;
        ComponentMetaData.FireInformation(1, "CreateNewOutputRows", "starting", "", 0, debug);

        declareString = buildDeclareString(ReadFromSQL2(debug));
        insertString = buildInsertIntoTablesString(ReadFromSQL2(debug));
        selectString = buildSelectString(ReadFromSQL2(debug));
        joinString = buildJoinString(ReadFromSQL2(debug));

        sqlString = buildInsertQueryString(declareString, insertString, selectString, joinString);
        ComponentMetaData.FireInformation(1, "sql string", sqlString, "", 0, debug);

        executeSqlCommand(sqlString, debug);

        Output0Buffer.AddRow();
        Output0Buffer.derp = sqlString;

        ComponentMetaData.FireInformation(1, "CreateNewOutputRows", "ending", "", 0, debug);
    }
}]]></arrayElement>
