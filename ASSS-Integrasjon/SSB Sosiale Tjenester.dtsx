        <DTS:Executable
          DTS:refId="Package\Sosiale tjenester\Les SSB_11864 Kvalifiseringsstønad, sosialhjelp og Husbankens bostøtte"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
