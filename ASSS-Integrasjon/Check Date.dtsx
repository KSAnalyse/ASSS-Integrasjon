            <component
              refId="Package\Data Flow Task\OLE DB Command"
              componentClassID="Microsoft.OLEDBCommand"
              contactInfo="OLE DB Command;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;2"
              description="Runs an SQL statement for each row in a data flow. For example, call a 'new employee setup' stored procedure for each row in the 'new employees' table. Note: running an SQL statement for each row of a large data flow may take a long time."
              name="OLE DB Command"
              usesDispositions="true"
              version="2">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">Declare @Kildeid varchar(10)
Declare @Tabellnummer varchar(10)
Declare @Dato_Publisert date
Declare @Last_Updated date
Declare @Gruppe varchar(100)

Set @Kildeid = ?
Set @Tabellnummer = ?
Set @Dato_Publisert = ?
Set @Last_Updated = ?
Set @Gruppe = ?

UPDATE Tabell_Publisert
SET Dato_Publisert = @Dato_Publisert
WHERE Tabellnummer = @Tabellnummer
IF @@ROWCOUNT=0
INSERT INTO Tabell_Publisert
	(Kildeid,Tabellnummer, Dato_Publisert, Last_Updated, Gruppe)
VALUES
	(@Kildeid, @Tabellnummer, @Dato_Publisert, @Last_Updated, @Gruppe)	</property>
                <property
