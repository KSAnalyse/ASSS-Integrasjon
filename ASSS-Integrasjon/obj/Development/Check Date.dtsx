                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">Declare @Kildeid varchar(10)
Declare @Tabellnummer varchar(10)
Declare @Dato_Publisert date
Declare @Last_Updated date
Declare @Gruppe varchar(100)

Set @Kildeid = ?
Set @Tabellnummer = ?
Set @Dato_Publisert = ?
Set @Last_Updated = ?
Set @Gruppe = ?

UPDATE Tabell_Publisert
SET Dato_Publisert = @Dato_Publisert
WHERE Tabellnummer = @Tabellnummer
IF not Exists (SELECT Tabellnummer FROM Tabell_Publisert WHERE Tabellnummer = @Tabellnummer)
INSERT INTO Tabell_Publisert
	(Kildeid,Tabellnummer, Dato_Publisert, Last_Updated, Gruppe)
VALUES
	(@Kildeid, @Tabellnummer, @Dato_Publisert, @Last_Updated, @Gruppe)	</property>
