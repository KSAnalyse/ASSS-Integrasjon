Declare @Tabellnummer varchar(10)
Declare @Tabellnavn varchar(200)
Declare @LagTabellFilter varchar(128)
Declare @HentDataFilter varchar(128)
Declare @Dato_Publisert date
Declare @Last_Updated date
Declare @Gruppe varchar(100)

Set @Kildeid = ?
Set @Tabellnummer = ?
Set @Dato_Publisert = ?
Set @Last_Updated = ?
Set @Gruppe = ?
Set @LagTabellFilter = ?
Set @HentDataFilter = ?
Set @Tabellnavn = ?

UPDATE Tabellinformasjon
SET Dato_Publisert = @Dato_Publisert, [Lag Tabell Filter] = @LagTabellFilter, [Hent Data Filter] = @HentDataFilter, Gruppe = @Gruppe, Tabellnavn = @Tabellnavn, Kildeid = @Kildeid
WHERE Tabellnummer = @Tabellnummer

IF not Exists (SELECT Tabellnummer FROM Tabellinformasjon WHERE Tabellnummer = @Tabellnummer)
INSERT INTO Tabellinformasjon
	(Kildeid,Tabellnummer, Tabellnavn, [Lag Tabell Filter], [Hent Data Filter], Dato_Publisert, Last_Updated, Gruppe)
VALUES
	(@Kildeid, @Tabellnummer, @Tabellnavn, @LagTabellFilter, @HentDataFilter, @Dato_Publisert, @Last_Updated, @Gruppe)	</property>
