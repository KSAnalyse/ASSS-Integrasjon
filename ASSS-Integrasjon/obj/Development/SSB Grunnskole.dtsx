not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;&#xA;-- Executes&#xA;Exec sp_executesql @Truncate_Query&#xA;&#xA;Insert Into [SSB_12919 Lærere i grunnskole, etter kjønn, lærerkompetanse]&#xA;&#xA;Select&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Kjonnkode,&#xA;&#x9;&#x9;met.Kjonnnavn,&#xA;&#x9;&#x9;dat.Kompetansekode,&#xA;&#x9;&#x9;met2.Kompetansenavn,&#xA;&#x9;&#x9;dat.Variabel ,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA;&#xA;from @t dat &#xA;Join @m met On met.Kjonnkode = dat.Kjonnkode&#xA;Join @m2 met2 On met2.Kompetansekode = dat.Kompetansekode&#xA;Join @m3 met3 On met3.Variabel = dat.Variabel&#xA;&#xA;-- Lærere (antall)&#xA;-- Begge kjønn&#xA;Where dat.Variabel = 'KOSantlarergrsk0000'&#xA;AND dat.Kjonnkode != '0'&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
