                      dataType="System.String"><![CDATA[#region Help:  Introduction to the Script Component
/* The Script Component allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services data flow.
 *
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script component. */
#endregion

#region Namespaces
using System;
using System.Collections.Generic;
using System.Data;
using System.Data.SqlClient;
using System.Linq;
using System.Windows.Forms;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;
#endregion

/// <summary>
/// This is the class to which to add your code.  Do not change the name, attributes, or parent
/// of this class.
/// </summary>
[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    #region Help:  Using Integration Services variables and parameters
    /* To use a variable in this script, first ensure that the variable has been added to
     * either the list contained in the ReadOnlyVariables property or the list contained in
     * the ReadWriteVariables property of this script component, according to whether or not your
     * code needs to write into the variable.  To do so, save this script, close this instance of
     * Visual Studio, and update the ReadOnlyVariables and ReadWriteVariables properties in the
     * Script Transformation Editor window.
     * To use a parameter in this script, follow the same steps. Parameters are always read-only.
     *
     * Example of reading from a variable or parameter:
     *  DateTime startTime = Variables.MyStartTime;
     *
     * Example of writing to a variable:
     *  Variables.myStringVariable = "new value";
     */
    #endregion

    #region Help:  Using Integration Services Connnection Managers
    /* Some types of connection managers can be used in this script component.  See the help topic
     * "Working with Connection Managers Programatically" for details.
     *
     * To use a connection manager in this script, first ensure that the connection manager has
     * been added to either the list of connection managers on the Connection Managers page of the
     * script component editor.  To add the connection manager, save this script, close this instance of
     * Visual Studio, and add the Connection Manager to the list.
     *
     * If the component needs to hold a connection open while processing rows, override the
     * AcquireConnections and ReleaseConnections methods.
     * 
     * Example of using an ADO.Net connection manager to acquire a SqlConnection:
     *  object rawConnection = Connections.SalesDB.AcquireConnection(transaction);
     *  SqlConnection salesDBConn = (SqlConnection)rawConnection;
     *
     * Example of using a File connection manager to acquire a file path:
     *  object rawConnection = Connections.Prices_zip.AcquireConnection(transaction);
     *  string filePath = (string)rawConnection;
     *
     * Example of releasing a connection manager:
     *  Connections.SalesDB.ReleaseConnection(rawConnection);
     */
    #endregion

    #region Help:  Firing Integration Services Events
    /* This script component can fire events.
     *
     * Example of firing an error event:
     *  ComponentMetaData.FireError(10, "Process Values", "Bad value", "", 0, out cancel);
     *
     * Example of firing an information event:
     *  ComponentMetaData.FireInformation(10, "Process Values", "Processing has started", "", 0, fireAgain);
     *
     * Example of firing a warning event:
     *  ComponentMetaData.FireWarning(10, "Process Values", "No rows were received", "", 0);
     */
    #endregion
    private SqlConnection scn;
    private SqlCommand command;
    private SqlDataReader dataReader;
    private string connectionString, sqlString, result;
    /// <summary>
    /// This method is called once, before rows begin to be processed in the data flow.
    ///
    /// You can remove this method if you don't need to do anything here.
    /// </summary>
    public override void PreExecute()
    {
        base.PreExecute();
        // Set the connectionString and the SqlConnection
        connectionString = @"Data Source=vk-sxd0e-003;Initial Catalog=TEST_Staging_ASSS;Integrated Security=true";
        scn = new SqlConnection(connectionString);

        // Set the sqlString and the Sql command
        sqlString = "select COLUMN_NAME, DATA_TYPE, CHARACTER_MAXIMUM_LENGTH, NUMERIC_PRECISION, NUMERIC_SCALE from INFORMATION_SCHEMA.columns where TABLE_NAME = 'SSB_" 
            + Variables.tableNumber + "'";
        command = new SqlCommand(sqlString, scn);
    }

    /// <summary>
    /// This method is called after all the rows have passed through this component.
    ///
    /// You can delete this method if you don't need to do anything here.
    /// </summary>
    public override void PostExecute()
    {
        base.PostExecute();
        /*
         * Add your code here
         */
        Variables.sqlVar = result;
    }

    public Dictionary<string, Dictionary<string, string>> ReadFromSQL()
    {
        bool fireAgain = true;
        Dictionary<string, Dictionary<string, string>> columns = new Dictionary<string, Dictionary<string, string>>();
        List<string[]> outPut = new List<string[]>();

        // Open the SQL connection
        this.ComponentMetaData.FireInformation(1, "SQL Connection", "opening", "", 0, ref fireAgain);
        scn.Open();
        this.ComponentMetaData.FireInformation(1, "SQL Connection", "open", "", 0, ref fireAgain);

        // Execute the SQL command
        this.ComponentMetaData.FireInformation(1, "Data reader", "executing", "", 0, ref fireAgain);
        dataReader = command.ExecuteReader();

        // Read the result of the command into the dictionary
        this.ComponentMetaData.FireInformation(1, "Data reader", "starting to read data from table " + Variables.tableNumber, "", 0, ref fireAgain);
        while (dataReader.Read())
        {
            Dictionary<string, string> columnValues = new Dictionary<string, string>();

            this.ComponentMetaData.FireInformation(1, "Data reader", "reading column " + dataReader.GetValue(0), "", 0, ref fireAgain);

            columnValues.Add("data_type", "" + dataReader.GetValue(1));
            columnValues.Add("char_max_length", "" + dataReader.GetValue(2));
            columnValues.Add("num_prec", "" + dataReader.GetValue(3));
            columnValues.Add("num_scale", "" + dataReader.GetValue(4));

            columns.Add("" + dataReader.GetValue(0), columnValues);
        }
        this.ComponentMetaData.FireInformation(1, "Data reader", "finished", "", 0, true);

        // Close the datareader
        this.ComponentMetaData.FireInformation(1, "Data reader", "closing", "", 0, ref fireAgain);
        dataReader.Close();
        this.ComponentMetaData.FireInformation(1, "Data reader", "closed", "", 0, ref fireAgain);

        // Clear the command
        command.Dispose();

        // Close the server connection
        this.ComponentMetaData.FireInformation(1, "SQL Connection", "closing", "", 0, ref fireAgain);
        scn.Close();
        this.ComponentMetaData.FireInformation(1, "SQL Connection", "closed", "", 0, ref fireAgain);

        return columns;
    }

    public string buildInsertQuery(Dictionary<string, Dictionary<string, string>> columns, bool debug)
    {
        string tDeclarations = "", mDeclarations = "";
        string tDeclarationString, mDeclarationString, insertTableString, insertIntoString, insertExecString, truncateString, selectString, sqlString;
        string mJoinString = "", selectColumns = "";
        string navnString="", kodeString="";
        int mCount = 0;

        insertTableString = "insert @t Exec SSB_Values_AlleAar2 @TabellNummer='" + Variables.tableNumber + "'\n";
        
        // TODO: endre disse til å bruke navnet i databasen
        truncateString = "Truncate Table [SSB_" + Variables.tableNumber + "]\n";
        insertIntoString = "Insert Into [SSB_" + Variables.tableNumber + "]\n"; 

        // Go through each of the key pairs in the dict. Each key corresponds to a column in the table
        // {statistikkvariabelnavn: {properties1: 1, ... }}
        foreach (KeyValuePair<string, Dictionary<string, string>> ckvp in columns)
        {
            // If the column contains navn then its a @m only column
            if (ckvp.Key.Contains("navn"))
            {
                // statistikkvariabelnavn varchar(størrelse)
                navnString = ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + "),";
                mDeclarations = mDeclarations + navnString + kodeString;
                // met0.statistikkvariabelnavn
                selectColumns = selectColumns + "\tmet" + mCount + "." + ckvp.Key;

                // If its not the last column then we add a comma
                if (columns.Keys.Last() != ckvp.Key)
                {
                    //mDeclarations = mDeclarations + ", ";
                    selectColumns = selectColumns + ",";
                }
                // Lineshift for better readability in the final string
                selectColumns = selectColumns + "\n";

                mJoinString = mJoinString + "Join @m met" + mCount + " ON met" + mCount + "." + ckvp.Key.Replace("navn", "kode")
                        + " = dat." + ckvp.Key.Replace("navn", "kode") + "\n";
                insertTableString = insertTableString + "insert @m Exec SSB_Metadata @TabellNummer='" + Variables.tableNumber + "'\n";
                
                mCount++;

            } else
            {
                // Switch on the datatype of the key as each have different declaration syntax
                switch (columns[ckvp.Key]["data_type"])
                {
                    case "varchar":
                        if (ckvp.Key.Contains("kode") && !ckvp.Key.Equals("Regionkode"))
                        {
                            kodeString = ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + ")";
                        }
                        tDeclarations = tDeclarations + ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + ")";

                        if (ckvp.Key.Equals("Tid"))
                        {
                            mDeclarations = mDeclarations + ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + ")";
                            mDeclarations = mDeclarations + ", " + ckvp.Key + "2 " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + ")";
                        } else if(ckvp.Key.Equals("Regionkode"))
                        {
                            mDeclarations = mDeclarations + ckvp.Key.Replace("kode", "navn") + " " + ckvp.Value["data_type"] + "(100), ";
                            mDeclarations = mDeclarations + ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["char_max_length"] + ")";
                        }
                        selectColumns = selectColumns + "\tdat." + ckvp.Key;
                        break;
                    case "int":
                        tDeclarations = tDeclarations + ckvp.Key + " " + ckvp.Value["data_type"];
                        mDeclarations = mDeclarations + ckvp.Key + " " + ckvp.Value["data_type"];
                        selectColumns = selectColumns + "\tdat." + ckvp.Key;
                        break;
                    case "numeric":
                        tDeclarations = tDeclarations + ckvp.Key + " " + ckvp.Value["data_type"] + "(" + ckvp.Value["num_prec"] + "," + ckvp.Value["num_scale"] + ")";
                        //mDeclarations = mDeclarations + ckvp.Key + " " +  ckvp.Value["data_type"] + "(" + ckvp.Value["num_prec"] + "," + ckvp.Value["num_scale"] + ")";
                        selectColumns = selectColumns + "\tdat." + ckvp.Key;
                        break;
                }

                if (columns.Keys.Last() != ckvp.Key)
                {
                    if (ckvp.Key.Contains("kode") && !ckvp.Key.Contains("Region"))
                    {
                        kodeString = kodeString + ", ";
                    } else if (!ckvp.Key.Equals("Tid"))
                        mDeclarations = mDeclarations + ", ";

                    tDeclarations = tDeclarations + ", ";
                    selectColumns = selectColumns + ",\n";
                }
            }
        }

        // These are always the same so just add the declarations
        tDeclarationString = $"declare @t table({tDeclarations})\n";
        mDeclarationString = $"declare @m table({mDeclarations})\n";

        // This is always the same so just add the columns and joins
        selectString = $"select {selectColumns}\nfrom @t dat\n{mJoinString}";

        ComponentMetaData.FireInformation(1, "Content filters", Variables.contentFilters, "", 0, ref debug);

        // If there are specified filters then we add these to the Exec string
        if (!Variables.contentFilters.Equals(""))
        {
            insertExecString = "insert @t Exec SSB_Values_AlleAar2 @TabellNummer='" + Variables.tableNumber + "', @Filter='" + Variables.contentFilters + "'\n";
        } else
        {
            insertExecString = "insert @t Exec SSB_Values_AlleAar2 @TabellNummer='" + Variables.tableNumber + "'\n";
        }

        // This is always the same so just add the tablenumber
        insertExecString = insertExecString + "insert @m Exec SSB_Metadata @TabellNummer='" + Variables.tableNumber + "'\n";

        // Add all the strings to one string
        sqlString = $"{tDeclarationString}{mDeclarationString}\n{insertExecString}\n{truncateString}\n{insertIntoString}\n{selectString}";
        ComponentMetaData.FireInformation(1, "SQL query", sqlString, "", 0, ref debug);

        return sqlString;
    }

    public override void CreateNewOutputRows()
    {
        // TODO: Add your code here

        result = buildInsertQuery(ReadFromSQL(), true);

        //this.ComponentMetaData.FireInformation(1, "Result", outPut, "", 0, ref fireAgain);
        //Dts.Variables["m_columns"].Value = outPut;
        //MessageBox.Show(outPut);
        //Dts.TaskResult = (int)ScriptResults.Success;
        /*
          Add rows by calling the AddRow method on the member variable named "<Output Name>Buffer".
          For example, call MyOutputBuffer.AddRow() if your output was named "MyOutput".
        */
        Output0Buffer.AddRow();
        Output0Buffer.derp = result;
    }
}
