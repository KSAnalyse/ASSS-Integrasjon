        {
            return (String)(ParentComponent.ReadWriteVariables["sqlVar"].GetValueWithContext(ScriptComponent.EvaluatorContext));
        }
        set
        {
            ParentComponent.ReadWriteVariables["sqlVar"].Value = value;
        }
    }

}
