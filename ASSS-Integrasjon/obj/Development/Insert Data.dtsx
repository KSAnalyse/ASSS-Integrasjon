    <DTS:Executable
      DTS:refId="Package\Get columndeclarations"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:Disabled="True"
      DTS:DTSID="{EC45E66C-AED9-4E1E-A69B-007866929C13}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Get columndeclarations"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
          SQLTask:SqlStatementSource="-- Holds the declarations for the two tables&#xA;Declare @m_column_decl nvarchar (700)&#xA;Declare @t_column_decl nvarchar(700)&#xA;&#xA;-- Counts the amount of columns to later know how many joins we need&#xA;Declare @m_amount_of_columns int&#xA;&#xA;-- Used to hold the different values for each row in tmpTable&#xA;Declare @column_name nvarchar(200)&#xA;Declare @data_type nvarchar(100)&#xA;Declare @character_maximum_length int&#xA;Declare @numeric_precision int&#xA;Declare @numeric_scale int&#xA;&#xA;-- Drop any existing table&#xA;If OBJECT_ID('tempdb..#tmpTable') IS NOT NULL&#xA;&#x9;Drop Table #tmpTable&#xA;&#xA;-- Creates a table based on the values in the information schema with the corresponding tablecode&#xA;select COLUMN_NAME, DATA_TYPE, CHARACTER_MAXIMUM_LENGTH, NUMERIC_PRECISION, NUMERIC_SCALE&#xA;Into #tmpTable&#xA;from INFORMATION_SCHEMA.columns&#xA;where TABLE_NAME LIKE '%' + ? + '%'&#xA;&#xA;Set @m_amount_of_columns =  (&#xA;&#x9;Select COUNT(*) from #tmpTable&#xA;&#x9;Where COLUMN_NAME NOT IN ('Regionkode', 'Tid', 'Verdi')&#xA;&#x9;AND COLUMN_NAME LIKE ('%navn')&#xA;)&#xA;&#xA;-- Loop through the rows in tmpTable, deleting the top one after storing the values in variables&#xA;While EXISTS(Select * From #tmpTable)&#xA;Begin&#xA;&#x9;Set @column_name = (select top 1 column_name from #tmpTable)&#xA;&#x9;Set @data_type = (select top 1 data_type from #tmpTable)&#xA;&#x9;Set @character_maximum_length = (select top 1 character_maximum_length from #tmpTable)&#xA;&#x9;Set @numeric_precision = (select top 1 numeric_precision from #tmpTable)&#xA;&#x9;Set @numeric_scale = (select top 1 numeric_scale from #tmpTable)&#xA;&#xA;&#x9;Delete #tmpTable Where column_name = (Select Top 1 column_name From #tmpTable)&#xA;&#xA;&#x9;-- The t table contains only codes and values, not the names&#xA;&#x9;IF @column_name NOT LIKE '%navn%'&#xA;&#x9;Begin&#xA;&#x9;&#x9;Set @t_column_decl = CASE&#xA;&#x9;&#x9;&#x9;When @column_name NOT LIKE ('%navn%') AND @data_type = 'varchar' Then Concat(@t_column_decl, '[' + @column_name + '] ' + @data_type + '(' + CAST(@character_maximum_length AS varchar) + ')')&#xA;&#x9;&#x9;&#x9;When @data_type = 'int' Then CONCAT(@t_column_decl, '[' + @column_name + '] ' + @data_type)&#xA;&#x9;&#x9;&#x9;When @data_type = 'numeric' Then CONCAT(@t_column_decl, '[' + @column_name + '] ' + @data_type + '(' + CAST(@numeric_precision AS varchar) + ',' + CAST(@numeric_scale AS varchar) + ')')&#xA;&#x9;&#x9;End&#xA;&#xA;&#x9;&#x9;-- If this isn't the last row, add a comma to the declaration list&#xA;&#x9;&#x9;IF EXISTS (Select TOP(1) * From #tmpTable)&#xA;&#x9;&#x9;Begin&#xA;&#x9;&#x9;&#x9;Set @t_column_decl = CONCAT(@t_column_decl, ', ')&#xA;&#x9;&#x9;End&#xA;&#x9;End&#xA;&#xA;&#x9;-- The m table contains everything&#xA;&#x9;Set @m_column_decl = Case&#xA;&#x9;&#x9;When @data_type = 'varchar' Then CONCAT(@m_column_decl, '[' + @column_name + '] ' + @data_type + '(' + CAST(@character_maximum_length AS varchar) + ')')&#xA;&#x9;&#x9;When @data_type = 'int' Then CONCAT(@m_column_decl, '[' + @column_name + '] ' + @data_type)&#xA;&#x9;&#x9;When @data_type = 'numeric' Then CONCAT(@m_column_decl, '[' + @column_name + '] ' + @data_type + '(' + CAST(@numeric_precision AS varchar) + ',' + CAST(@numeric_scale AS varchar) + ')')&#xA;&#x9;End&#xA;&#xA;&#x9;IF EXISTS (Select TOP(1) * From #tmpTable)&#xA;&#x9;Begin&#xA;&#x9;&#x9;Set @m_column_decl = CONCAT(@m_column_decl, ', ')&#xA;&#x9;End&#xA;End&#xA;&#xA;-- t_columns&#xA;Select ? = @t_column_decl&#xA;&#xA;--m_columns&#xA;Select ? = @m_column_decl&#xA;&#xA;-- amount of columns to decide how many @m joins we need&#xA;Select ? = @m_amount_of_columns&#xA;&#xA;Drop Table #tmpTable" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="$Project::tableNumber"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="5" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::t_columns"
            SQLTask:ParameterDirection="Output"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="700" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="2"
            SQLTask:DtsVariableName="User::m_columns"
            SQLTask:ParameterDirection="Output"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="700" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="3"
            SQLTask:DtsVariableName="User::m_count"
            SQLTask:ParameterDirection="Output"
            SQLTask:DataType="4"
            SQLTask:ParameterSize="0" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
