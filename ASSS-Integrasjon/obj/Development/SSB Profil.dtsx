            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
              SQLTask:SqlStatementSource="-- Variabels&#xA;Declare @TableVar varchar(5)&#xA;Declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;Declare @Truncate_Query nvarchar(200)&#xA;&#xA;Set @TableVar = '07459'&#xA;Set @TableName = (SELECT table_name FROM information_schema.tables WHERE table_name LIKE'SSB_' + @TableVar + '%')&#xA;&#xA;Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;Declare @t table(Regionkode varchar(4), Kjønnkode varchar(1), Alderkode varchar(4), Statistikkvariabelkode varchar(9), År Int, Verdi numeric(18,0))&#xA;&#x9;Declare @m table(Regionnavn varchar (50), Regionkode varchar(4), Kjønnnavn varchar(7), Kjønnkode varchar(1) , Aldernavn varchar(18), Alderkode varchar(4), Statistikkvariabelnavn varchar(8), Statistikkvariabelkode varchar(9), År Int, År2 Int)&#xA;&#x9;Declare @m2 table(Regionnavn varchar (50), Regionkode varchar(4), Kjønnnavn varchar(7), Kjønnkode varchar(1) , Aldernavn varchar(18), Alderkode varchar(4), Statistikkvariabelnavn varchar(8), Statistikkvariabelkode varchar(9), År Int, År2 Int)&#xA;&#x9;Declare @m3 table(Regionnavn varchar (50), Regionkode varchar(4), Kjønnnavn varchar(7), Kjønnkode varchar(1) , Aldernavn varchar(18), Alderkode varchar(4), Statistikkvariabelnavn varchar(8), Statistikkvariabelkode varchar(9), År Int, År2 Int)&#xA;&#x9;-- Inserts&#xA;&#x9;Insert @t Exec SSB_Values_AlleAar2 @TabellNummer=@TableVar, @Filter=&quot;Tid=2015,2016,2017,2018,2019,2020&quot;&#xA;&#x9;Insert @m Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m2 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m3 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;Exec sp_executesql @Truncate_Query&#xA;&#xA;Insert into [SSB_07459]&#xA;&#xA;Select&#x9;dat.Regionkode,&#xA;&#x9;&#x9;dat.Kjønnkode,&#xA;&#x9;&#x9;met.Kjønnnavn,&#xA;&#x9;&#x9;dat.Alderkode,&#xA;&#x9;&#x9;met2.Aldernavn,&#xA;&#x9;&#x9;dat.Statistikkvariabelkode,&#xA;&#x9;&#x9;met3.Statistikkvariabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat &#xA;Join @m met On  met.Kjønnkode = dat.Kjønnkode&#xA;Join @m2 met2 On met2.Alderkode = dat.Alderkode&#xA;Join @m3 met3 On met3.Statistikkvariabelkode = dat.Statistikkvariabelkode&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
