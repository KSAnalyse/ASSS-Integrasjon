275]&#xA;&#xA;Select&#x9;dat.Regionkode,&#xA;&#x9;&#x9;dat.Alderskode,&#xA;&#x9;&#x9;met.Alder,&#xA;&#x9;&#x9;dat.Funksjonskode,&#xA;&#x9;&#x9;met2.Funksjon,&#xA;&#x9;&#x9;dat.Statistikkvariabelkode,&#xA;&#x9;&#x9;met3.Statistikkvariabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Alderskode = dat.Alderskode&#xA;Join @m2 met2 ON met2.Funksjonskode = dat.Funksjonskode&#xA;Join @m3 met3 ON met3.Statistikkvariabelkode = dat.Statistikkvariabelkode&#xA;&#xA;--Barn med barnevernstiltak i løpet av året (antall)&#xA;--Barn med barnevernstiltak per 31.12 (antall)&#xA;Where dat.Statistikkvariabelkode IN ('KOSbvbarntiltaka0000', 'KOSbvbarntiltak30001')&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
