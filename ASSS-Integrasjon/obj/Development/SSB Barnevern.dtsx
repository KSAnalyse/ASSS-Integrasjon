              SQLTask:SqlStatementSource="&#xA;&#xA;-- Variabels&#xA;Declare @TableVar varchar(5)&#xA;Declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;Declare @Truncate_Query nvarchar(200)&#xA;&#xA;Set @TableVar = '12280'&#xA;Set @TableName = (SELECT table_name FROM information_schema.tables WHERE table_name LIKE'SSB_' + @TableVar + '%')&#xA;&#xA;Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;declare @t table(Regionkode varchar(50), Statistikkvariabelkode varchar(50), År Int, Verdi numeric(18,4))&#xA;&#x9;declare @m table(Regionnavn Varchar(150), Regionkode varchar(50), Statistikkvariabelnavn varchar(150), Statistikkvariabelkode varchar(50), År Int, År2 Int)&#xA;&#xA;&#x9;-- Inserts&#xA;&#x9;Insert @t Exec SSB_Values_AlleAar2 @TabellNummer=@TableVar&#xA;&#x9;Insert @m Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;Exec sp_executesql @Truncate_Query&#xA;&#xA;Insert into [SSB_12280]&#xA;&#xA;Select&#x9;dat.Regionkode,&#xA;&#x9;&#x9;dat.Statistikkvariabelkode ,&#xA;&#x9;&#x9;met.Statistikkvariabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat &#xA;Join @m met&#xA;ON met.Statistikkvariabelkode = dat.Statistikkvariabelkode&#xA;&#xA;-- Undersøkingar med handsamingstid innan 3 månader (prosent)&#xA;-- Barn med undersøking eller tiltak per årsverk (funksjon 244) (antall)&#xA;Where dat.Statistikkvariabelkode IN ('KOSbehandlingsti0001', 'KOSbarnmtiltuspa0000')&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
