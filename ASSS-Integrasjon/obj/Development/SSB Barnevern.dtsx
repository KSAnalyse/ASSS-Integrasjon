            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
              SQLTask:SqlStatementSource="&#xA;&#xA;-- Variabels&#xA;Declare @TableVar varchar(5)&#xA;Declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;Declare @Truncate_Query nvarchar(200)&#xA;&#xA;Set @TableVar = '12189'&#xA;-- Possible code to automate the insert into section&#xA;Set @TableName = (SELECT table_name FROM information_schema.tables WHERE table_name LIKE'SSB_' + @TableVar + '%')&#xA;&#xA;Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;declare @t table(Regionkode varchar(50), Konklusjonskode varchar(50), Behandlingskode int, Statistikkvariabelkode varchar(50),År Int,Verdi numeric(18,4))&#xA;&#x9;declare @m table(Regionnavn Varchar(150), Regionkode varchar(50), Konklusjon varchar(150), Konklusjonskode varchar(50), Behandlingstid varchar(150), Behandlingskode varchar(50), Statistikkvariabelnavn varchar(150), Statistikkvariabelkode varchar(50), År Int, År2 Int)&#xA;&#x9;declare @m2 table(Regionnavn Varchar(150), Regionkode varchar(50), Konklusjon varchar(150), Konklusjonskode varchar(50), Behandlingstid varchar(150), Behandlingskode varchar(50), Statistikkvariabelnavn varchar(150), Statistikkvariabelkode varchar(50), År Int, År2 Int)&#xA;&#x9;declare @m3 table(Regionnavn Varchar(150), Regionkode varchar(50), Konklusjon varchar(150), Konklusjonskode varchar(50), Behandlingstid varchar(150), Behandlingskode varchar(50), Statistikkvariabelnavn varchar(150), Statistikkvariabelkode varchar(50), År Int, År2 Int)&#xA;&#xA;&#x9;-- Inserts&#xA;&#x9;Insert @t Exec SSB_Values_AlleAar2 @TabellNummer='12189'&#xA;&#x9;Insert @m Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m2 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m3 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;Exec sp_executesql @Truncate_Query&#xA;&#xA;Insert into [SSB_12189]&#xA;&#xA;Select&#x9;dat.Regionkode,&#xA;&#x9;&#x9;dat.Konklusjonskode,&#xA;&#x9;&#x9;met.Konklusjon,&#xA;&#x9;&#x9;dat.Behandlingskode,&#xA;&#x9;&#x9;met2.Behandlingstid,&#xA;&#x9;&#x9;dat.Statistikkvariabelkode,&#xA;&#x9;&#x9;met3.Statistikkvariabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Konklusjonskode = dat.Konklusjonskode&#xA;Join @m2 met2 ON met2.Behandlingskode = dat.Behandlingskode&#xA;Join @m3 met3 ON met3.Statistikkvariabelkode = dat.Statistikkvariabelkode&#xA;&#xA;--Meldinger til barnevernet (antall)&#xA;Where dat.Statistikkvariabelkode = 'KOSmelding0000'&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
