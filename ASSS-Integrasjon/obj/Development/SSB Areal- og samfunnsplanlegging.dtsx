              SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
              SQLTask:SqlStatementSource="USE [TEST_Staging_ASSS]&#xA;&#xA;-- Variabels&#xA;declare @TableVar varchar(5)&#xA;declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;declare @Truncate_Query nvarchar(200)&#xA;&#xA;-- Tabellen man henter data fra&#xA;Set @TableVar = '12920'&#xA;Set @TableName = (select table_name from information_schema.tables where table_name LIKE 'SSB_' + @TableVar + '%')&#xA;&#xA;-- Går innhenting greit tømmes tabellen&#xA;Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;-- Prøv å hente data og sett dette inn i variabler&#xA;-- Bruker SSB_Values_AlleAar for å hente data fra SSB og SSB_Metadata for å hente metadata&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;-- Deklarerer midlertidige tabeller for å holde dataene&#xA;&#x9;-- Trenger en tabell per ekstra dimensjon&#xA;&#x9;Declare @t Table(Sektorkode varchar(50), Kommunenummer varchar(50), Postkode varchar(50),  Variabel varchar(50), År Int,Verdi numeric(18,1))&#xA;&#x9;Declare @m Table(Sektornavn varchar(150), Sektorkode varchar(50), Kommune varchar(150), Kommunenummer varchar(50), Postnavn varchar(150), Postkode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#x9;Declare @m2 Table(Sektornavn varchar(150), Sektorkode varchar(50), Kommune varchar(150), Kommunenummer varchar(50), Postnavn varchar(150), Postkode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#x9;Declare @m3 Table(Sektornavn varchar(150), Sektorkode varchar(50), Kommune varchar(150), Kommunenummer varchar(50), Postnavn varchar(150), Postkode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#xA;&#x9;-- Inserts&#xA;&#x9;-- Setter inn data i de midlertidige tabellene ved bruk av skript&#xA;&#x9;Insert @t Exec SSB_Values_AlleAar @TabellNummer=@TableVar, @Omfang=0&#xA;&#x9;Insert @m Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m2 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m3 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;exec sp_executesql @Truncate_Query&#xA;&#xA;insert into [SSB_12920 Selvkostregnskap, etter tjenesteområde, post]&#xA;&#xA;Select&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Sektorkode,&#xA;&#x9;&#x9;met.Sektornavn,&#xA;&#x9;&#x9;dat.Postkode,&#xA;&#x9;&#x9;met2.Postnavn,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA;&#xA;from @t dat Join @m met ON met.Sektorkode = dat.Sektorkode&#xA;Join @m2 met2 ON met2.Postkode = dat.Postkode&#xA;Join @m3 met3 On met3.Variabel = dat.Variabel&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
