            VariableName="User::All_tables" />
        </DTS:ObjectData>
      </DTS:ForEachEnumerator>
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\Foreach Loop Container\Execute SQL Task"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{AB832D8F-C405-49C8-8F1C-A35638A455D2}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
              SQLTask:SqlStatementSource="USE [TEST_Staging_ASSS]&#xA;&#xA;Declare @CreateTable nvarchar(800);&#xA;Declare @DropTableSql nvarchar(300)&#xA;Declare @TableName nvarchar (300)&#xA;Declare @ColumnDecl nvarchar (700)&#xA;Declare @DBName nvarchar(100)&#xA;Declare @droptable bit&#xA;&#xA;Declare @column_name nvarchar(200)&#xA;Declare @data_type nvarchar(100)&#xA;Declare @character_maximum_length int&#xA;Declare @numeric_precision int&#xA;Declare @numeric_scale int&#xA;&#xA;Set @ColumnDecl = ''&#xA;&#xA;Set @DBName = (Select DB_NAME())&#xA;&#xA;/* Hvis det eksisterer et tmpTable så fjern dette */&#xA;If OBJECT_ID('tempdb..#tmpTable') IS NOT NULL&#xA;&#x9;Drop Table #tmpTable&#xA;&#xA;/* tmpTable inneholder deklarasjonene fra Lag_Spørring prosedyren */&#xA;Create Table #tmpTable&#xA;(&#xA;&#x9;table_name varchar(50),&#xA;&#x9;column_name nvarchar(100),&#xA;&#x9;data_type nvarchar(100),&#xA;&#x9;character_maximum_length int,&#xA;&#x9;numeric_precision int,&#xA;&#x9;numeric_scale int&#xA;)&#xA;&#xA;/* Legg inn kolonnedeklarasjonene i tmpTable fra Lag_Spørring prosedyren*/&#xA;Insert into #tmpTable&#xA;EXEC SSB_Lag_Kolonnedeklarasjon_Dataframe_v2 @SSBTableCode = ?&#xA;&#xA;/* Første rad inneholder tabellnavnet på formen SSB_Tabellnavn */&#xA;Set @TableName = (Select Top 1 @column_name From #tmpTable)&#xA;&#xA;/* Hvis en av verdiene i tmpTable ikke eksisterer i information_schema settes droptable til 1 */&#xA;IF EXISTS(&#xA;&#x9;select tt.HashValue From&#xA;&#x9;(select HASHBYTES('md5', CONCAT_WS('|', column_name, data_type, character_maximum_length, numeric_precision, numeric_scale)) AS HashValue from #tmpTable) tt&#xA;&#x9;left outer JOIN (select HASHBYTES('md5', CONCAT_WS('|', column_name, data_type, character_maximum_length, numeric_precision, numeric_scale)) AS HashValue from INFORMATION_SCHEMA.COLUMNS where TABLE_NAME = @TableName) isc &#xA;&#x9;ON (isc.HashValue = tt.HashValue) Where isc.HashValue is null&#xA;&#x9;)&#xA;Begin&#xA;&#x9;Select 'Eksisterer ikke!'&#xA;&#x9;Set @droptable = 1&#xA;End&#xA;&#xA;/* Loop gjennom tmpTable og fjern radene etter de er blitt lagt til i ColumnDecl strengen */&#xA;While EXISTS(Select * From #tmpTable)&#xA;Begin&#xA;&#x9;Set @column_name = (select top 1 column_name from #tmpTable)&#xA;&#x9;Set @data_type = (select top 1 data_type from #tmpTable)&#xA;&#x9;Set @character_maximum_length = (select top 1 character_maximum_length from #tmpTable)&#xA;&#x9;Set @numeric_precision = (select top 1 numeric_precision from #tmpTable)&#xA;&#x9;Set @numeric_scale = (select top 1 numeric_scale from #tmpTable)&#xA;&#xA;&#x9;Set @ColumnDecl = Case&#xA;&#x9;&#x9;When @data_type = 'varchar' Then CONCAT(@ColumnDecl, @column_name + ' ' + @data_type + '(' + CAST(@character_maximum_length AS varchar) + ')')&#xA;&#x9;&#x9;When @data_type = 'int' Then CONCAT(@ColumnDecl, @column_name + ' ' + @data_type)&#xA;&#x9;&#x9;When @data_type = 'numeric' Then CONCAT(@ColumnDecl, @column_name + ' ' + @data_type + '(' + CAST(@numeric_precision AS varchar) + ',' + CAST(@numeric_scale AS varchar) + ')')&#xA;&#x9;End&#xA;&#xA;&#x9;IF (Select COUNT(*) From #tmpTable) &gt; 1&#xA;&#x9;&#x9;Set @ColumnDecl = CONCAT(@ColumnDecl, ', ')&#xA;&#xA;&#x9;Delete #tmpTable Where column_name = (Select Top 1 column_name From #tmpTable)&#xA;End&#xA;&#xA;IF (@droptable = 1)&#xA;Begin&#xA;&#x9;Set @DropTableSql = N'Drop Table ' + @DBName + '.dbo.' + '[' + @TableName + ']'&#xA;&#x9;Exec sp_executesql @DropTableSql&#xA;End&#xA;&#xA;IF Not EXISTS(Select table_name From INFORMATION_SCHEMA.COLUMNS Where TABLE_NAME = @TableName)&#xA;Begin&#xA;&#x9;Set @CreateTable = N'&#xA;&#x9;&#x9;Create Table ' + @DBName + '.dbo.' + '[' + @TableName + '] (' + @ColumnDecl + ')'&#xA;&#x9;&#xA;&#x9;Execute sp_executesql @CreateTable&#xA;End&#xA;&#xA;Drop Table #tmpTable&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::All_tables"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="129"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
