      DTS:LocaleID="-1"
      DTS:ObjectName="Foreach Loop Container">
      <DTS:ForEachEnumerator
        DTS:CreationName="Microsoft.ForEachFromVarEnumerator"
        DTS:DTSID="{C27A774B-AC92-46BA-9450-28F04754CE8C}"
        DTS:ObjectName="{C27A774B-AC92-46BA-9450-28F04754CE8C}">
