          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9F001A7A-8CE8-471A-9A5B-1A85E2289A4E}"
              SQLTask:SqlStatementSource="&#xA;&#xA;-- Variabels&#xA;declare @TableVar varchar(5)&#xA;declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;declare @Truncate_Query nvarchar(200)&#xA;&#xA;set @TableVar = '12150'&#xA;set @TableName = (select table_name from information_schema.tables where table_name LIKE 'SSB_' + @TableVar + '%')&#xA;&#xA;set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;-- Prøv å hente data og sett dette inn i variabler&#xA;-- Bruker SSB_Values_AlleAar for å hente data fra SSB og SSB_Metadata for å hente metadata&#xA;begin try&#xA;&#x9;-- declares&#xA;&#x9;declare @t table(Kommunenummer varchar(50), Funksjonskode varchar(50), Energikode varchar(50), Variabel varchar(50), År Int,Verdi numeric(18,1))&#xA;&#x9;declare @m table(Kommune varchar(150), Kommunenummer varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Energinavn varchar(150), Energikode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#x9;declare @m2 table(Kommune varchar(150), Kommunenummer varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Energinavn varchar(150), Energikode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#x9;declare @m3 table(Kommune varchar(150), Kommunenummer varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Energinavn varchar(150), Energikode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År int, År2 int)&#xA;&#x9;&#xA;&#x9;-- inserts&#xA;&#x9;insert @t exec SSB_Values_AlleAar2 @TabellNummer=@TableVar&#xA;&#x9;insert @m exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;insert @m2 exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;insert @m3 exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;exec sp_executesql @Truncate_Query&#xA;&#xA;insert into [SSB_12150]&#xA;&#xA;Select&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Funksjonskode,&#xA;&#x9;&#x9;met.Funksjonsnavn,&#xA;&#x9;&#x9;dat.Energikode,&#xA;&#x9;&#x9;met2.Energinavn,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Funksjonskode = dat.Funksjonskode&#xA;Join @m2 met2 ON met2.Energikode = dat.Energikode&#xA;Join @m3 met3 ON met3.Variabel = dat.Variabel&#xA;&#xA;-- Alle energityper&#xA;Where dat.Energikode = 'AG99'&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
