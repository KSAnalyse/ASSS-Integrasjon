            <SQLTask:SqlTaskData
              SQLTask:Connection="{06B55A42-C604-46E3-A3FF-04F23BE8A234}"
              SQLTask:SqlStatementSource="Use [TEST_Staging_ASSS]&#xA;&#xA;-- Variabels&#xA;Declare @TableVar varchar(5)&#xA;Declare @TableName varchar(150)&#xA;&#xA;-- Query variabels&#xA;Declare @Truncate_Query nvarchar(200)&#xA;&#xA;Set @TableVar = '08655'&#xA;Set @TableName = (SELECT table_name FROM information_schema.tables WHERE table_name LIKE'SSB_' + @TableVar + '%')&#xA;&#xA;Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;-- Prøv å hente data og sett dette inn i variabler&#xA;-- Bruker SSB_Values_AlleAar for å hente data fra SSB og SSB_Metadata for å hente metadata&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;Declare @t Table(Byggekostnadkode varchar(50), Variabel varchar(50), År varchar(7), Verdi numeric(18,4))&#xA;&#x9;Declare @m Table(Byggekostnadnavn varchar(150), Byggekostnadkode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År varchar(7), År2 varchar(7))&#xA;&#x9;Declare @m2 Table(Byggekostnadnavn varchar(150), Byggekostnadkode varchar(50), Variabelnavn varchar(150), Variabel varchar(50), År varchar(7), År2 varchar(7))&#xA;&#x9;&#xA;&#x9;-- Inserts&#xA;&#x9;Insert @t Exec SSB_Values_AlleAar2 @TabellNummer=@TableVar&#xA;&#x9;Insert @m Exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;Insert @m2 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;&#xA;-- Executes&#xA;Exec sp_executesql @Truncate_Query&#xA;&#xA;Insert Into [SSB_08655 Byggjekostnadsindeks for bustadblokk, arbeidstype]&#xA;&#xA;Select&#x9;sk.Kommunenummer,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met.Variabelnavn,&#xA;&#x9;&#x9;LEFT(dat.År, 4), &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Variabel = dat.Variabel&#xA;Join @m2 met2 ON met2.Byggekostnadkode = dat.Byggekostnadkode&#xA;Join (Select * From [SSB_Kommuner] Where Kommunenummer IN ('0106', '0219', '0301', '0602', '1001', '1102', '1103', '1201', '1902', '5001')) sk ON sk.Kommunenummer != dat.Variabel&#xA;&#xA;-- Månedlige data, ønsker bare data for januar og de siste 3 årene&#xA;Where RIGHT(dat.År, 2) = '01' AND LEFT(dat.År, 4) &gt;= YEAR(GETDATE())-3 &#xA;&#xA;-- Bustadblokk i alt&#xA;AND dat.Variabel = 'Byggindeks' AND dat.Byggekostnadkode = '20'&#xA;&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
