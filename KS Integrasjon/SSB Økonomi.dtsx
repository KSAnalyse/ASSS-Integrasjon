      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2017; © 2017 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="10">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06B55A42-C604-46E3-A3FF-04F23BE8A234}"
          SQLTask:SqlStatementSource="USE [TEST_Staging_ASSS]&#xA;&#xA;-- Variabels&#xA;declare @TableVar varchar(5)&#xA;declare @TableName varchar(150)&#xA;declare @ConFilter varchar(200)&#xA;declare @Year int&#xA;&#xA;-- Query variabels&#xA;declare @Truncate_Query nvarchar(200)&#xA;&#xA;Set @TableVar = '12367'&#xA;Set @TableName = (select table_name from information_schema.tables where table_name LIKE 'SSB_' + @TableVar + '%')&#xA;Set @Year = ?&#xA;Set @ConFilter = CONCAT('KOKregnskapsomfa0000=A&amp;Tid=', CAST(@Year as VARCHAR(4)))&#xA;&#xA;-- Set @Truncate_Query = N'Truncate Table [' + @TableName + ']'&#xA;&#xA;-- Prøv å hente data og sett dette inn i variabler&#xA;-- Bruker SSB_Values_AlleAar for å hente data fra SSB og SSB_Metadata for å hente metadata&#xA;begin try&#xA;&#x9;-- Declares&#xA;&#x9;declare @t table(Kommunenummer varchar(50), Omfangskode varchar(50), Funksjonskode varchar(50),Artkode varchar(50), Variabel varchar(50), År int, Verdi numeric(18,4))&#xA;&#x9;declare @m table(Kommune Varchar(150), Kommunenummer varchar(50), Omfangsnavn varchar(150), Omfangskode varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Artnavn varchar(150), Artkode varchar(50),  Variabelnavn varchar(150), Variabel varchar(50), År int, År2 Int)&#xA;&#x9;declare @m2 table(Kommune Varchar(150), Kommunenummer varchar(50), Omfangsnavn varchar(150), Omfangskode varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Artnavn varchar(150), Artkode varchar(50),  Variabelnavn varchar(150), Variabel varchar(50), År int, År2 Int)&#xA;&#x9;declare @m3 table(Kommune Varchar(150), Kommunenummer varchar(50), Omfangsnavn varchar(150), Omfangskode varchar(50), Funksjonsnavn varchar(150), Funksjonskode varchar(50), Artnavn varchar(150), Artkode varchar(50),  Variabelnavn varchar(150), Variabel varchar(50), År int, År2 Int)&#xA;&#x9;&#xA;&#x9;-- Inserts&#xA;&#x9;insert @t exec SSB_Values_AlleAar2 @TabellNummer=@TableVar, @Filter=@ConFilter&#xA;&#x9;BEGIN TRY&#xA;&#x9;&#x9;DECLARE @table_check bigint&#xA;&#x9;&#x9;DECLARE @kek bigint&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;SET @table_check = (SELECT CHECKSUM_AGG(CHECKSUM(Kommunenummer, Funksjonskode, Artkode, Variabel, År, Verdi)) FROM @t)&#xA;&#x9;&#x9;SET @kek = (SELECT CHECKSUM_AGG(CHECKSUM(Kommunenummer, Funksjonkode, Artkode, Variabel, År, Verdi)) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;FROM dbo.[SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art] WHERE År = @Year)&#xA;&#x9;&#x9;PRINT @table_check&#xA;&#x9;&#x9;PRINT @kek&#xA;&#x9;&#x9;IF @table_check = @kek&#xA;&#x9;&#x9;&#x9;BEGIN&#xA;&#x9;&#x9;&#x9;&#x9;PRINT 'Same table'&#xA;&#x9;&#x9;&#x9;&#x9;SET NOEXEC ON&#xA;&#x9;&#x9;&#x9;END&#xA;&#x9;&#x9;&#xA;&#x9;END TRY&#xA;&#x9;BEGIN CATCH&#xA;&#x9;&#x9;RAISERROR('Checksum failed', 18, 1, @TableVar)&#xA;&#x9;END CATCH&#xA;&#x9;insert @m exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;--insert @m2 exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;--insert @m3 exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;-- exec sp_executesql @Truncate_Query&#xA;&#xA;DELETE FROM [SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art] WHERE År = @Year&#xA;&#xA;INSERT INTO [SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art]&#xA;&#xA;SELECT&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Funksjonskode,&#xA;&#x9;&#x9;met.Funksjonsnavn,&#xA;&#x9;&#x9;dat.Artkode,&#xA;&#x9;&#x9;met2.Artnavn,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;FROM @t dat&#xA;JOIN @m met ON&#x9;met.Funksjonskode = dat.Funksjonskode&#xA;Join @m met2 On met2.Artkode = dat.Artkode&#xA;Join @m met3 On met3.Variabel = dat.Variabel&#xA;&#xA;set noexec off"
