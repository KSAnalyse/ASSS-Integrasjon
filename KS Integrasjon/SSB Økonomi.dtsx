G(CHECKSUM(Kommunenummer, Funksjonskode, Artkode, Variabel, År, Verdi)) FROM @t)&#xA;&#x9;&#x9;SET @kek = (SELECT CHECKSUM_AGG(CHECKSUM(Kommunenummer, Funksjonkode, Artkode, Variabel, År, Verdi)) FROM dbo.[SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art] WHERE År = 2015)&#xA;&#x9;&#x9;PRINT @table_check&#xA;&#x9;&#x9;PRINT @kek&#xA;&#x9;&#x9;IF @table_check = @kek&#xA;&#x9;&#x9;&#x9;BEGIN&#xA;&#x9;&#x9;&#x9;&#x9;PRINT 'Same table'&#xA;&#x9;&#x9;&#x9;&#x9;SET NOEXEC ON&#xA;&#x9;&#x9;&#x9;END&#xA;&#x9;&#x9;&#xA;&#x9;END TRY&#xA;&#x9;BEGIN CATCH&#xA;&#x9;&#x9;RAISERROR('Checksum failed', 18, 1, @TableVar)&#xA;&#x9;END CATCH&#xA;&#x9;insert @m exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;--insert @m2 exec SSB_Metadata @TabellNummer=@TableVar&#xA;&#x9;--insert @m3 exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;-- exec sp_executesql @Truncate_Query&#xA;&#xA;DELETE FROM [SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art] WHERE År = 2015&#xA;&#xA;INSERT INTO [SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art]&#xA;&#xA;SELECT&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Funksjonskode,&#xA;&#x9;&#x9;met.Funksjonsnavn,&#xA;&#x9;&#x9;dat.Artkode,&#xA;&#x9;&#x9;met2.Artnavn,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;FROM @t dat&#xA;JOIN @m met ON&#x9;met.Funksjonskode = dat.Funksjonskode&#xA;Join @m met2 On met2.Artkode = dat.Artkode&#xA;Join @m met3 On met3.Variabel = dat.Variabel&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
