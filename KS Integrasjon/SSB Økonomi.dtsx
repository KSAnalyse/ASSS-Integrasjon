    <DTS:Executable
      DTS:refId="Package\Les SSB_12367 Detaljerte regnskapstall driftsregnskapet, regnskapsomfang, funksjon, art 2019"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:Disabled="True"
      DTS:DTSID="{6ae038c8-924d-4ad9-a9b2-da0797fbe2fb}"
