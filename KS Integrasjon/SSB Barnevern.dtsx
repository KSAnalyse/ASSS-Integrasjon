cutesql @Truncate_Query&#xA;&#xA;Insert into [SSB_12189 Meldingar til barnevernet, konklusjon på meldinga, handsamingstid av meldinga]&#xA;&#xA;Select&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Konklusjonskode,&#xA;&#x9;&#x9;met.Konklusjon,&#xA;&#x9;&#x9;dat.Behandlingskode,&#xA;&#x9;&#x9;met2.Behandlingstid,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Konklusjonskode = dat.Konklusjonskode&#xA;Join @m2 met2 ON met2.Behandlingskode = dat.Behandlingskode&#xA;Join @m3 met3 ON met3.Variabel = dat.Variabel&#xA;&#xA;--Meldinger til barnevernet (antall)&#xA;Where dat.Variabel = 'KOSmelding0000'&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
