@TabellNummer=@TableVar&#xA;&#x9;insert @m3 Exec SSB_Metadata @TabellNummer=@TableVar&#xA;end try&#xA;&#xA;-- Noe gikk galt ved henting av data. Koden som følger skal derfor ikke eksekveres&#xA;begin catch&#xA;&#x9;RAISERROR('Did not find values in the table %s',18, 1, @TableVar)&#xA;&#x9;set noexec on&#xA;end catch&#xA;&#xA;-- Executes&#xA;exec sp_executesql @Truncate_Query&#xA;&#xA;insert into [SSB_12003 Omsorgstjenester - brukere, etter alder, tjenestegrupper]&#xA;&#xA;Select&#x9;dat.Kommunenummer,&#xA;&#x9;&#x9;dat.Alderskode,&#xA;&#x9;&#x9;met.Alder,&#xA;&#x9;&#x9;dat.Tjenestegruppekode,&#xA;&#x9;&#x9;met2.Tjenestegruppe,&#xA;&#x9;&#x9;dat.Variabel,&#xA;&#x9;&#x9;met3.Variabelnavn,&#xA;&#x9;&#x9;dat.År, &#xA;&#x9;&#x9;dat.Verdi&#xA; &#xA;from @t dat&#xA;Join @m met ON met.Alderskode = dat.Alderskode&#xA;Join @m2 met2 ON met2.Tjenestegruppekode = dat.Tjenestegruppekode&#xA;Join @m3 met3 ON met3.Variabel = dat.Variabel&#xA;&#xA;-- Brukere (antall)&#xA;Where dat.Variabel = 'KOSomsorgantbruk0000'&#xA;&#xA;set noexec off" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
